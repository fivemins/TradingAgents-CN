# Core LLM routing
TRADINGAGENTS_LLM_PROVIDER=ark
TRADINGAGENTS_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
TRADINGAGENTS_LLM_API_KEY=your-llm-api-key
TRADINGAGENTS_QUICK_LLM=doubao-seed-2.0-lite
TRADINGAGENTS_DEEP_LLM=doubao-seed-2.0-pro

# Optional compatibility aliases
ARK_API_KEY=your-ark-api-key
OPENAI_API_KEY=

# Local embedding service
TRADINGAGENTS_EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
TRADINGAGENTS_EMBEDDING_MODEL=bge-m3:latest
TRADINGAGENTS_EMBEDDING_API_KEY=

# Optional data keys
FINNHUB_API_KEY=
QVERIS_API_KEYS=key1,key2,key3,key4
QVERIS_API_KEY=

# Dashboard runtime
TRADINGAGENTS_DASHBOARD_DATA_DIR=
TRADINGAGENTS_DASHBOARD_CORS=http://localhost:5173,http://127.0.0.1:5173
